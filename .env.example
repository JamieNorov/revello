# ── GoHighLevel ───────────────────────────────────────────────
# Settings → Integrations → Private Integrations → Create new
GHL_PRIVATE_TOKEN=your_ghl_private_integration_token_here

# Your sub-account Location ID (visible in GHL URL)
GHL_LOCATION_ID=your_location_id_here

GHL_BASE_URL=https://services.leadconnectorhq.com

# Optional: webhook signing secret from GHL
GHL_WEBHOOK_SECRET=

# ── OpenAI ────────────────────────────────────────────────────
# platform.openai.com → API Keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Database (Supabase) ───────────────────────────────────────
# Supabase → Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Meta Ad Library (free) ───────────────────────────────────
# developers.facebook.com → Your App → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GHL_LOCATION_ID=your_location_id_here
